# PostgreSQL (Neon). Pooled connection for the app runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require&channel_binding=require"

# Direct (non-pooled) connection for Prisma schema operations / migrations.
# Same as DATABASE_URL but without the "-pooler" segment in the host.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# Auth.js / admin seed placeholders. Do not commit real values.
AUTH_SECRET="generate-with-openssl-rand-base64-33"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="replace-with-a-strong-password"
